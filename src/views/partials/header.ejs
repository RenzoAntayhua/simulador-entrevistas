<!-- Lógica Global de Socket.io para rastreo de usuarios conectados -->
<script src="/socket.io/socket.io.js"></script>
<script>
    <% if (userName) { %>
        // Solo conectamos al socket si hay un userName disponible
        const globalSocket = io();
        globalSocket.emit('usuario-conectado', { nombre: '<%= userName %>', id: '<%= userId %>' });

        globalSocket.on('invitacion-recibida', (data) => {
            if (confirm(`⚔️ ¡${data.retador} te ha desafiado a una batalla de código!\nReto: "${data.reto}"\n\n¿Aceptas el reto?`)) {
                window.location.href = `/batalla/${data.codigo}`;
            } else {
                globalSocket.emit('invitacion-rechazada', { codigo: data.codigo });
            }
        });
    <% } %>
</script>