<div class="admin-mobile-header-bar">
    <button id="adminMobileMenuToggleBtn" class="admin-hamburger-btn">
        ☰
    </button>
    <span class="admin-mobile-logo-title">Admin Panel</span>
    <div style="width: 24px;"></div>
</div>

<div class="admin-sidebar">
    <button id="adminSidebarCloseBtn" class="admin-drawer-close-btn" style="display: none;">✕</button>
    <h3>Admin Panel</h3>
    <ul>
        <li><a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>">📊 Dashboard</a></li>
        <li><a href="/admin/usuarios" class="<%= currentPath && currentPath.startsWith('/admin/usuarios') ? 'active' : '' %>">👥 Usuarios</a></li>
        <li><a href="/admin/retos" class="<%= currentPath && currentPath.startsWith('/admin/retos') ? 'active' : '' %>">🔥 Retos</a></li>
        <li><a href="/admin/bancos" class="<%= currentPath && currentPath.startsWith('/admin/bancos') ? 'active' : '' %>">📚 Bancos</a></li>
        <li><a href="/admin/reporte/pdf" target="_blank">📄 Reporte (PDF)</a></li>
        <li><a href="/logout" class="btn-logout">🚪 Cerrar Sesión</a></li>
    </ul>
    
    <div style="padding: 15px 20px; margin-top: 10px;">
        <button id="adminThemeToggleBtn" style="width: 100%; padding: 10px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; border-radius: 8px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s;">
            <span id="adminThemeIcon">☀️</span> Modo Claro
        </button>
    </div>
</div>

<script>
    // Prevenir destello de colores cargando el tema antes de que la página renderice completamente
    if (localStorage.getItem('theme') === 'light') {
        document.documentElement.classList.add('light-theme');
        document.body && document.body.classList.add('light-theme');
    }

    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('adminThemeToggleBtn');
        const icon = document.getElementById('adminThemeIcon');
        
        if (localStorage.getItem('theme') === 'light') {
            document.body.classList.add('light-theme');
            document.documentElement.classList.add('light-theme');
            if (btn) btn.innerHTML = '🌙 Modo Oscuro';
        }
        
        btn?.addEventListener('click', () => {
            const isLight = document.body.classList.toggle('light-theme');
            document.documentElement.classList.toggle('light-theme', isLight);
            if (isLight) {
                localStorage.setItem('theme', 'light');
                btn.innerHTML = '🌙 Modo Oscuro';
            } else {
                localStorage.setItem('theme', 'dark');
                btn.innerHTML = '☀️ Modo Claro';
            }
        });

        // Toggle de menú lateral en admin
        const adminSidebar = document.querySelector('.admin-sidebar');
        const adminToggleBtn = document.getElementById('adminMobileMenuToggleBtn');
        const adminCloseBtn = document.getElementById('adminSidebarCloseBtn');
        
        function closeAdminMenu() {
            adminSidebar.classList.remove('menu-open');
            document.getElementById('adminMenuBackdrop')?.remove();
            document.body.style.overflow = ''; // Habilitar scroll del body
        }
        
        adminToggleBtn?.addEventListener('click', (e) => {
            e.stopPropagation();
            adminSidebar.classList.toggle('menu-open');
            if (adminSidebar.classList.contains('menu-open')) {
                document.getElementById('adminMenuBackdrop')?.remove();
                document.body.style.overflow = 'hidden'; // Deshabilitar scroll del body
                
                const backdrop = document.createElement('div');
                backdrop.id = 'adminMenuBackdrop';
                backdrop.style.position = 'fixed';
                backdrop.style.top = '0';
                backdrop.style.left = '0';
                backdrop.style.width = '100vw';
                backdrop.style.height = '100vh';
                backdrop.style.backgroundColor = 'rgba(0,0,0,0.5)';
                backdrop.style.zIndex = '9998';
                document.body.appendChild(backdrop);
                
                backdrop.addEventListener('click', () => {
                    closeAdminMenu();
                });
            } else {
                closeAdminMenu();
            }
        });

        adminCloseBtn?.addEventListener('click', () => {
            closeAdminMenu();
        });

        // Cerrar menú al presionar cualquier enlace del admin sidebar
        const adminLinks = adminSidebar.querySelectorAll('a');
        adminLinks.forEach(link => {
            link.addEventListener('click', () => {
                closeAdminMenu();
            });
        });
    });
</script>