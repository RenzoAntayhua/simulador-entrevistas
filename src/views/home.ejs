<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Simulador</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body style="margin: 0;">
    
    <%- include('partials/header') %>

    <main class="main-content">
        <div style="text-align: center; margin-bottom: 3rem;">
            <h1 style="color: var(--primary); font-size: 2.5rem; margin-bottom: 0.5rem;">¡Bienvenido, <%= nombre %>! 🚀</h1>
            <p style="font-size: 1.1rem; color: var(--text-muted);">Administra tus simuladores técnicos o explora los de la comunidad.</p>
        </div>

        <!-- SECCIÓN DE GRÁFICAS DE PROGRESO (NUEVO) -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
            <!-- Radar Chart -->
            <div class="card glass-effect" style="margin-bottom: 0;">
                <h3 style="text-align: center; margin-bottom: 1rem;">📡 Radar de Habilidades</h3>
                <div style="position: relative; height: 250px; width: 100%;">
                    <canvas id="radarChart"></canvas>
                </div>
            </div>
            
            <!-- Activity Chart -->
            <div class="card glass-effect" style="margin-bottom: 0;">
                <h3 style="text-align: center; margin-bottom: 1rem;">🔥 Actividad (Últimos 7 días)</h3>
                <div style="position: relative; height: 250px; width: 100%;">
                    <canvas id="activityChart"></canvas>
                </div>
            </div>
        </div>

        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
            <h2 style="margin: 0;">Mis Simuladores</h2>
            <a href="/bancos/crear" class="btn" style="width: auto; background-color: var(--success);">+ Crear Nuevo Simulador</a>
        </div>

        <hr style="border: 0; border-top: 1px solid var(--border-color); margin-bottom: 2rem;">

        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
            <% if (bancos && bancos.length > 0) { %>
                <% bancos.forEach(banco => { %>
                    <div class="card" style="display: flex; flex-direction: column; border-top: 4px solid var(--primary); margin-bottom: 0; transition: transform 0.2s, box-shadow 0.2s;">
                        <div style="flex: 1;">
                            <h3 style="margin-bottom: 0.5rem; color: var(--text-main); font-size: 1.25rem;"><%= banco.titulo %></h3>
                            <p style="font-size: 0.95rem; color: var(--text-muted); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; margin-bottom: 1rem;">
                                <%= banco.descripcion %>
                            </p>
                        </div>
                        
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--border-color);">
                            <span class="categoria">
                                <%= banco.categoria %>
                            </span>
                            <span style="font-weight: 600; color: #F59E0B; display: flex; align-items: center; gap: 0.25rem;" title="<%= banco.total_votos || 0 %> votos">
                                <%= banco.promedio ? Number(banco.promedio).toFixed(1) : '0.0' %> ⭐ <small style="font-size: 0.75rem; color: var(--text-muted);">(<%= banco.total_votos || 0 %>)</small>
                            </span>
                        </div>

                        <a href="/bancos/ver/<%= banco.id %>" class="btn btn-secondary text-center">
                            Gestionar Simulador
                        </a>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="card text-center" style="grid-column: 1 / -1; border-style: dashed; padding: 3rem;">
                    <p style="margin-bottom: 1rem; font-size: 1.1rem; color: var(--text-muted);">Aún no has creado ningún simulador de entrevistas.</p>
                    <a href="/bancos/crear" class="btn" style="width: auto; display: inline-block;">¡Crea tu primer simulador aquí!</a>
                </div>
            <% } %>
        </div>

        <div style="margin-top: 4rem; text-align: center; border-top: 1px solid var(--border-color); padding-top: 2rem;">
            <a href="/bancos" style="color: var(--primary); text-decoration: none; font-weight: 600; font-size: 1.1rem;">Explorar simuladores de la comunidad →</a>
        </div>
    </main>

    <script>
        // Datos dinámicos desde el backend
        const dbRadarData = <%- JSON.stringify(radarData) %>;
        const dbActivityLabels = <%- JSON.stringify(activityLabels) %>;
        const dbActivityData = <%- JSON.stringify(activityData) %>;

        // Configuración dinámica basada en el tema actual
        const isLight = document.body.classList.contains('light-theme') || localStorage.getItem('theme') === 'light';
        const textColor = isLight ? '#475569' : '#a1a1aa';
        const gridColor = isLight ? '#e2e8f0' : '#2a2a2a';

        // 1. Radar Chart (Habilidades)
        const ctxRadar = document.getElementById('radarChart').getContext('2d');
        const radarChart = new Chart(ctxRadar, {
            type: 'radar',
            data: {
                labels: ['JavaScript', 'Python', 'Java', 'C++', 'C#', 'SQL'],
                datasets: [{
                    label: 'Retos Resueltos',
                    data: dbRadarData,
                    backgroundColor: 'rgba(99, 102, 241, 0.2)',
                    borderColor: '#6366f1',
                    pointBackgroundColor: '#6366f1',
                    pointHoverBackgroundColor: '#fff',
                    pointHoverBorderColor: '#6366f1',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    r: {
                        angleLines: { color: gridColor },
                        grid: { color: gridColor },
                        pointLabels: { color: textColor, font: { family: 'Inter', size: 12, weight: '500' } },
                        ticks: { display: false, suggestedMin: 0, suggestedMax: 5 }
                    }
                },
                plugins: { legend: { display: false } }
            }
        });

        // 2. Bar Chart (Actividad Reciente)
        const ctxActivity = document.getElementById('activityChart').getContext('2d');
        const activityChart = new Chart(ctxActivity, {
            type: 'bar',
            data: {
                labels: dbActivityLabels,
                datasets: [{
                    label: 'Retos Resueltos',
                    data: dbActivityData,
                    backgroundColor: '#22c55e', // Verde éxito
                    borderRadius: 4,
                    barPercentage: 0.6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { 
                        grid: { color: gridColor, drawBorder: false }, 
                        ticks: { color: textColor, precision: 0, suggestedMin: 0, suggestedMax: 5 } 
                    },
                    x: { 
                        grid: { display: false }, 
                        ticks: { color: textColor, font: { family: 'Inter' } } 
                    }
                },
                plugins: { legend: { display: false } }
            }
        });

        // Refrescar página silenciosamente si cambian el tema para re-renderizar la gráfica
        window.addEventListener('themeChanged', () => {
            window.location.reload();
        });
    </script>
</body>
</html>