<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usuarios - Simulador</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .usuarios-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; margin-top: 20px; }
        .usuario-card { background: #1a1a2e; padding: 20px; border-radius: 8px; border: 1px solid #2a2a4a; text-align: center; }
        .usuario-avatar { width: 60px; height: 60px; border-radius: 50%; background: #4f46e5; display: inline-flex; align-items: center; justify-content: center; font-size: 24px; font-weight: bold; margin-bottom: 10px; }
    </style>
</head>
<body>
    <%- include('../partials/header') %>
    <div class="container">
        <h2>👥 Explorar Usuarios</h2>
        <div class="usuarios-grid">
            <% if (usuarios && usuarios.length > 0) { %>
                <% usuarios.forEach(u => { %>
                    <div class="usuario-card">
                        <div class="usuario-avatar"><%= u.nombre.charAt(0).toUpperCase() %></div>
                        <h3><%= u.nombre %></h3>
                        <p style="color: #888; font-size: 14px; margin-bottom: 15px;">Jugador activo</p>
                        
                        <% if (u.estadoAmistad === 'aceptado') { %>
                            <span class="badge badge-Exitoso">✓ Amigo</span>
                        <% } else if (u.estadoAmistad === 'pendiente') { %>
                            <span class="badge badge-Medio">⌛ Solicitud Pendiente</span>
                        <% } else { %>
                            <form action="/amigos/agregar" method="POST">
                                <input type="hidden" name="amigo_id" value="<%= u.id %>">
                                <button type="submit" class="btn">Agregar a Amigos</button>
                            </form>
                        <% } %>
                    </div>
                <% }) %>
            <% } else { %>
                <p>No hay otros usuarios registrados aún.</p>
            <% } %>
        </div>
    </div>
</body>
</html>
